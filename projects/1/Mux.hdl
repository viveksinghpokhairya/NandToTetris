// File name: projects/1/Mux.hdl
/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    //// Replace this comment with your code.
    Not(in = sel, out = Notsel); 
    And(a = a, b = Notsel, out = aAndsel);
    And(a = sel, b = b, out = bAndNotsel);
    Or(a = aAndsel, b = bAndNotsel, out = out);
}